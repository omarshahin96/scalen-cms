<%- include('../partials/header', {title, active, user, success, error, locals}) %>
    <a href="/testimonials" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
<%- include('../partials/footer') %>

<form action="/testimonials<%= item ? '/' + item.id + '?_method=PUT' : '' %>" method="POST">
  <div class="card" style="max-width:700px">
    <div class="card-header"><div class="card-title"><%= item ? 'Edit Testimonial' : 'New Testimonial' %></div></div>
    <div class="form-grid form-grid-2">
      <div class="form-group">
        <label>Client Name *</label>
        <input type="text" name="name" value="<%= item ? item.name : '' %>" required>
      </div>
      <div class="form-group">
        <label>Rating (1-5)</label>
        <select name="rating">
          <% for(let i=5;i>=1;i--) { %><option value="<%= i %>" <%= (item && item.rating==i)?'selected':(!item&&i===5)?'selected':'' %>><%= '★'.repeat(i) %> <%= i %> Stars</option><% } %>
        </select>
      </div>
      <div class="form-group">
        <label>Job Title / Role</label>
        <input type="text" name="role" value="<%= item ? item.role || '' : '' %>" placeholder="CEO">
      </div>
      <div class="form-group">
        <label>Company</label>
        <input type="text" name="company" value="<%= item ? item.company || '' : '' %>" placeholder="Company Name">
      </div>
      <div class="form-group span-2">
        <label>Testimonial Quote *</label>
        <textarea name="quote" rows="4" required><%= item ? item.quote || '' : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Status</label>
        <select name="status">
          <option value="active" <%= (!item||item.status==='active')?'selected':'' %>>Active</option>
          <option value="inactive" <%= (item&&item.status==='inactive')?'selected':'' %>>Inactive</option>
        </select>
      </div>
      <div class="form-group">
        <label>Sort Order</label>
        <input type="number" name="sort_order" value="<%= item ? item.sort_order : 0 %>" min="0">
      </div>
    </div>
    <hr class="divider">
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> <%= item ? 'Update' : 'Add Testimonial' %></button>
      <a href="/testimonials" class="btn btn-ghost">Cancel</a>
    </div>
  </div>
</form>

<%- include('../partials/close') %>
