<%- include('../partials/header', {title, active, user, success, error, locals}) %>
    <a href="/blog/create" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> New Post</a>
    <a href="/blog/categories" class="btn btn-ghost btn-sm"><i class="fas fa-tags"></i> Categories</a>
<%- include('../partials/footer') %>

<!-- FILTERS -->
<form method="GET" action="/blog">
  <div class="d-flex gap-2 items-center mb-5" style="flex-wrap:wrap">
    <div class="search-bar" style="max-width:300px;flex:1">
      <i class="fas fa-search"></i>
      <input type="text" name="search" value="<%= query.search || '' %>" placeholder="Search posts…">
    </div>
    <select name="status" style="width:auto;padding:10px 13px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:#fff;font-size:14px;" onchange="this.form.submit()">
      <option value="">All Status</option>
      <option value="draft" <%= query.status==='draft'?'selected':'' %>>Draft</option>
      <option value="published" <%= query.status==='published'?'selected':'' %>>Published</option>
    </select>
    <select name="category" style="width:auto;padding:10px 13px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:#fff;font-size:14px;" onchange="this.form.submit()">
      <option value="">All Categories</option>
      <% categories.forEach(c => { %><option value="<%= c.id %>" <%= query.category==c.id?'selected':'' %>><%= c.name %></option><% }) %>
    </select>
    <% if (query.search || query.status || query.category) { %>
      <a href="/blog" class="btn btn-ghost btn-sm">Clear</a>
    <% } %>
    <button type="submit" class="btn btn-ghost btn-sm"><i class="fas fa-filter"></i> Filter</button>
  </div>
</form>

<div class="card">
  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-newspaper"></i>
      <h3>No posts found</h3>
      <p>Create your first blog post to get started.</p>
      <a href="/blog/create" class="btn btn-primary mt-4" style="margin-top:16px"><i class="fas fa-plus"></i> New Post</a>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Author</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% posts.forEach(post => { %>
            <tr>
              <td>
                <div style="font-weight:700;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= post.title %></div>
                <% if (post.excerpt) { %><div class="text-grey text-sm" style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= post.excerpt %></div><% } %>
              </td>
              <td><% if (post.cat_name) { %><span class="badge badge-blue"><%= post.cat_name %></span><% } else { %>—<% } %></td>
              <td class="text-sm"><%= post.author %></td>
              <td><span class="badge badge-<%= post.status==='published'?'green':'grey' %>"><%= post.status %></span></td>
              <td class="text-grey text-sm"><%= new Date(post.created_at).toLocaleDateString() %></td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/blog/<%= post.id %>/edit" class="btn btn-ghost btn-sm btn-icon" title="Edit"><i class="fas fa-pen"></i></a>
                  <form action="/blog/<%= post.id %>?_method=DELETE" method="POST" data-confirm="Delete this post?">
                    <button type="submit" class="btn btn-danger btn-sm btn-icon" title="Delete"><i class="fas fa-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div style="padding:14px 0 2px;color:var(--grey);font-size:13px"><%= posts.length %> post<%= posts.length !== 1 ? 's' : '' %></div>
  <% } %>
</div>

<%- include('../partials/close') %>
