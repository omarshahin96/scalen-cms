<%- include('../partials/header', {title, active, user, success, error, locals}) %>
    <a href="/leads/export/csv" class="btn btn-green btn-sm"><i class="fas fa-download"></i> Export CSV</a>
<%- include('../partials/footer') %>

<!-- Status Tabs -->
<div class="d-flex gap-2 items-center mb-5" style="flex-wrap:wrap;justify-content:space-between">
  <div class="d-flex gap-2" style="flex-wrap:wrap">
    <a href="/leads" class="btn btn-sm <%= !query.status?'btn-primary':'btn-ghost' %>">All <span style="opacity:0.7;margin-left:4px">(<%= counts.all %>)</span></a>
    <a href="/leads?status=new" class="btn btn-sm <%= query.status==='new'?'btn-primary':'btn-ghost' %>">New <span style="opacity:0.7;margin-left:4px">(<%= counts.new %>)</span></a>
    <a href="/leads?status=read" class="btn btn-sm <%= query.status==='read'?'btn-primary':'btn-ghost' %>">Read <span style="opacity:0.7;margin-left:4px">(<%= counts.read %>)</span></a>
    <a href="/leads?status=replied" class="btn btn-sm <%= query.status==='replied'?'btn-primary':'btn-ghost' %>">Replied <span style="opacity:0.7;margin-left:4px">(<%= counts.replied %>)</span></a>
  </div>
  <form method="GET" action="/leads" class="d-flex gap-2">
    <% if (query.status) { %><input type="hidden" name="status" value="<%= query.status %>"><% } %>
    <div class="search-bar" style="max-width:260px">
      <i class="fas fa-search"></i>
      <input type="text" name="search" value="<%= query.search || '' %>" placeholder="Search leads…">
    </div>
    <button type="submit" class="btn btn-ghost btn-sm"><i class="fas fa-search"></i></button>
  </form>
</div>

<div class="card">
  <% if (leads.length === 0) { %>
    <div class="empty-state"><i class="fas fa-inbox"></i><h3>No leads found</h3><p>Contact form submissions will appear here.</p></div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Name</th><th>Email</th><th>Subject</th><th>Status</th><th>Date</th><th></th></tr></thead>
        <tbody>
          <% leads.forEach(l => { %>
            <tr>
              <td style="font-weight:700;white-space:nowrap">
                <% if(l.status==='new') { %><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--pink);margin-right:7px;flex-shrink:0;vertical-align:middle"></span><% } %>
                <%= l.name %>
              </td>
              <td class="text-sm text-grey"><%= l.email %></td>
              <td class="text-sm" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= l.subject || '—' %></td>
              <td><span class="badge badge-<%= l.status==='new'?'pink':l.status==='read'?'orange':'green' %>"><%= l.status %></span></td>
              <td class="text-grey text-sm white-nowrap"><%= new Date(l.created_at).toLocaleDateString() %></td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/leads/<%= l.id %>" class="btn btn-ghost btn-sm btn-icon" title="View"><i class="fas fa-eye"></i></a>
                  <form action="/leads/<%= l.id %>?_method=DELETE" method="POST" data-confirm="Delete this lead?">
                    <button type="submit" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div style="padding:12px 0 2px;color:var(--grey);font-size:13px"><%= leads.length %> lead<%= leads.length !== 1 ? 's' : '' %></div>
  <% } %>
</div>

<%- include('../partials/close') %>
