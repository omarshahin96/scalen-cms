<%- include('../partials/header', {title, active, user, success, error, locals}) %>
    <a href="/services/create" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> New Service</a>
<%- include('../partials/footer') %>

<div class="card">
  <% if (services.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-briefcase"></i>
      <h3>No services yet</h3>
      <a href="/services/create" class="btn btn-primary" style="margin-top:16px"><i class="fas fa-plus"></i> Add Service</a>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>#</th><th>Icon</th><th>Title</th><th>Status</th><th>Order</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% services.forEach(s => { %>
            <tr>
              <td class="text-grey text-sm"><%= s.id %></td>
              <td><i class="fas <%= s.icon %>" style="font-size:18px;color:var(--blue-lt)"></i></td>
              <td>
                <div style="font-weight:700"><%= s.title %></div>
                <div class="text-grey text-sm" style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= s.description %></div>
              </td>
              <td><span class="badge badge-<%= s.status==='active'?'green':'grey' %>"><%= s.status %></span></td>
              <td class="text-grey"><%= s.sort_order %></td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/services/<%= s.id %>/edit" class="btn btn-ghost btn-sm btn-icon"><i class="fas fa-pen"></i></a>
                  <form action="/services/<%= s.id %>?_method=DELETE" method="POST" data-confirm="Delete '<%= s.title %>'?">
                    <button type="submit" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/close') %>
