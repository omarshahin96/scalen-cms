<%- include('../partials/header', {title, active, user, success, error, locals}) %>
    <a href="/settings/password" class="btn btn-ghost btn-sm"><i class="fas fa-lock"></i> Change Password</a>
<%- include('../partials/footer') %>

<form action="/settings" method="POST">
  <div style="display:flex;flex-direction:column;gap:16px">
    <% const groupLabels = { general:'General', contact:'Contact Information', social:'Social Media', homepage:'Homepage Text', seo:'SEO & Meta', tracking:'Tracking & Analytics' }; %>
    <% Object.entries(grouped).forEach(([group, settings]) => { %>
      <div class="card">
        <div class="card-header">
          <div class="card-title"><%= groupLabels[group] || group.charAt(0).toUpperCase() + group.slice(1) %></div>
        </div>
        <div class="form-grid form-grid-2">
          <% settings.forEach(s => { %>
            <div class="form-group <%= (s.type === 'textarea') ? 'span-2' : '' %>">
              <label><%= s.label %></label>
              <% if (s.type === 'textarea') { %>
                <textarea name="settings[<%= s.key %>]" rows="3"><%= s.value || '' %></textarea>
              <% } else { %>
                <input type="<%= s.type || 'text' %>" name="settings[<%= s.key %>]" value="<%= s.value || '' %>" placeholder="<%= s.label %>">
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>

    <div>
      <button type="submit" class="btn btn-primary" style="min-width:160px"><i class="fas fa-save"></i> Save All Settings</button>
    </div>
  </div>
</form>

<%- include('../partials/close') %>
